# Server-side only — read by api/generate-trip.ts (Vercel serverless
# function). NEVER prefix this with VITE_: that would bundle it into the
# client-side JS, exposing it to anyone who opens DevTools.
ANTHROPIC_API_KEY=

# Server-side only — read by api/route.ts (proxies OpenRouteService so the
# key never reaches the browser). Free token from openrouteservice.org/dev.
OPENROUTESERVICE_API_KEY=

# Server-side only — read by api/generate-trip.ts (via api/_lib/placesVerify.ts).
# Google Places API (New) key. When set, every AI-suggested place is verified
# against Google Places at generation time (region-locked to the destination)
# and only real, findable places make it onto the map, with coordinates from
# Google. When UNSET, generation still works but falls back to the old
# client-side Nominatim geocoding (some places may not pin / may pin wrong).
# Setup: Google Cloud project -> enable "Places API (New)" -> create an API
# key -> enable billing (required even for the free tier). Recommend setting a
# quota cap so usage hard-stops at the free tier (5,000 Text Search Pro
# calls/month) and can never be charged. NEVER prefix with VITE_.
GOOGLE_PLACES_API_KEY=